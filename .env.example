# Copy this file to .env for local development.
# Never commit .env to version control.

# Required in production — set a long random string
SECRET_KEY=change-me-before-running-in-production

# Optional — defaults to SQLite for local dev
# DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/portfolio

# Optional — can be set via Admin → Settings in the UI instead
# OPENROUTER_API_KEY=sk-or-...

# Optional — override the default models
# OPENROUTER_CHAT_MODEL=openai/gpt-4o-mini
# OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small

# Optional — defaults shown
# MAX_UPLOAD_MB=20
# SESSION_TTL_HOURS=72
